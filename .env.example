# Supabase (required for database and auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth: login is required for dashboard when Supabase is configured. Set to false to allow access without login.
# REQUIRE_AUTH=false

# Optional: n8n webhook when a new ticket is created from the public form
# N8N_NEW_TICKET_WEBHOOK_URL=https://your-n8n.app/webhook/new-ticket
