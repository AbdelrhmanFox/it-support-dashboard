# Supabase (required for database and auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: require login for dashboard routes (public /support and /ticket-request always open)
# REQUIRE_AUTH=true

# Optional: n8n webhook when a new ticket is created from the public form
# N8N_NEW_TICKET_WEBHOOK_URL=https://your-n8n.app/webhook/new-ticket
